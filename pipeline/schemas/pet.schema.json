{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/lovely-pet/pet.schema.json",
  "title": "Lovely Pet Manifest",
  "type": "object",
  "required": ["id", "name", "scale", "anchor", "defaultState", "states"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "scale": { "type": "number", "minimum": 0.1, "maximum": 5 },
    "anchor": { "type": "string", "enum": ["bottom-right", "bottom-left", "center", "custom"] },
    "defaultState": { "type": "string", "minLength": 1 },
    "states": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["fps", "loop", "frames"],
        "properties": {
          "fps": { "type": "integer", "minimum": 1, "maximum": 60 },
          "loop": { "type": "boolean" },
          "frames": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "nextState": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
