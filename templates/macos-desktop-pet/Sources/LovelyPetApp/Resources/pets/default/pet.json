{
  "id": "default",
  "name": "Lovely Ragdoll",
  "renderer": {
    "type": "imageAssets"
  },
  "window": {
    "width": 320,
    "height": 340
  },
  "behavior": {
    "hoverState": "hover",
    "tapState": "tap",
    "sleepState": "sleep"
  },
  "scale": 1.0,
  "anchor": "bottom-right",
  "defaultState": "idle",
  "states": {
    "idle": {
      "fps": 12,
      "loop": true,
      "frames": [
        "frames/idle/0001.png",
        "frames/idle/0002.png",
        "frames/idle/0003.png",
        "frames/idle/0004.png",
        "frames/idle/0005.png",
        "frames/idle/0006.png",
        "frames/idle/0007.png",
        "frames/idle/0008.png",
        "frames/idle/0009.png",
        "frames/idle/0010.png"
      ],
      "exitFrames": [
        "frames/idle_to_hover/0001.png",
        "frames/idle_to_hover/0002.png"
      ]
    },
    "hover": {
      "fps": 16,
      "loop": true,
      "frames": [
        "frames/hover/0001.png",
        "frames/hover/0002.png",
        "frames/hover/0003.png",
        "frames/hover/0004.png",
        "frames/hover/0005.png",
        "frames/hover/0006.png",
        "frames/hover/0007.png",
        "frames/hover/0008.png"
      ],
      "exitFrames": [
        "frames/hover_to_idle/0001.png",
        "frames/hover_to_idle/0002.png"
      ]
    },
    "tap": {
      "fps": 18,
      "loop": false,
      "nextState": "idle",
      "frames": [
        "frames/tap/0001.png",
        "frames/tap/0002.png",
        "frames/tap/0003.png",
        "frames/tap/0004.png",
        "frames/tap/0005.png",
        "frames/tap/0006.png",
        "frames/tap/0007.png",
        "frames/tap/0008.png"
      ]
    },
    "sleep": {
      "fps": 8,
      "loop": true,
      "frames": [
        "frames/sleep/0001.png",
        "frames/sleep/0002.png",
        "frames/sleep/0003.png",
        "frames/sleep/0004.png",
        "frames/sleep/0005.png",
        "frames/sleep/0006.png",
        "frames/sleep/0007.png",
        "frames/sleep/0008.png"
      ]
    },
    "walk_right": {
      "fps": 14,
      "loop": true,
      "frames": [
        "frames/walk_right/0001.png",
        "frames/walk_right/0002.png",
        "frames/walk_right/0003.png",
        "frames/walk_right/0004.png",
        "frames/walk_right/0005.png",
        "frames/walk_right/0006.png",
        "frames/walk_right/0007.png",
        "frames/walk_right/0008.png",
        "frames/walk_right/0009.png",
        "frames/walk_right/0010.png"
      ]
    },
    "walk_left": {
      "fps": 14,
      "loop": true,
      "frames": [
        "frames/walk_left/0001.png",
        "frames/walk_left/0002.png",
        "frames/walk_left/0003.png",
        "frames/walk_left/0004.png",
        "frames/walk_left/0005.png",
        "frames/walk_left/0006.png",
        "frames/walk_left/0007.png",
        "frames/walk_left/0008.png",
        "frames/walk_left/0009.png",
        "frames/walk_left/0010.png"
      ]
    }
  }
}
