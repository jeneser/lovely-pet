{
  "id": "default",
  "name": "Lovely Ragdoll",
  "renderer": {
    "type": "imageAssets"
  },
  "window": {
    "width": 72,
    "height": 76
  },
  "behavior": {
    "hoverState": "hover",
    "tapState": "tap",
    "sleepState": "sleep"
  },
  "scale": 1.0,
  "anchor": "bottom-right",
  "defaultState": "idle",
  "states": {
    "idle": {
      "fps": 5,
      "loop": true,
      "frames": [
        "frames/idle/sheet.png#0",
        "frames/idle/sheet.png#3",
        "frames/idle/sheet.png#4",
        "frames/idle/sheet.png#5",
        "frames/idle/sheet.png#1",
        "frames/idle/sheet.png#6",
        "frames/idle/sheet.png#7",
        "frames/idle/sheet.png#8",
        "frames/idle/sheet.png#0",
        "frames/idle/sheet.png#9",
        "frames/idle/sheet.png#10",
        "frames/idle/sheet.png#11",
        "frames/idle/sheet.png#2",
        "frames/idle/sheet.png#12",
        "frames/idle/sheet.png#13",
        "frames/idle/sheet.png#14",
        "frames/idle/sheet.png#0"
      ]
    },
    "hover": {
      "fps": 8,
      "loop": true,
      "frames": [
        "frames/hover/sheet.png#0",
        "frames/hover/sheet.png#2",
        "frames/hover/sheet.png#3",
        "frames/hover/sheet.png#4",
        "frames/hover/sheet.png#1",
        "frames/hover/sheet.png#5",
        "frames/hover/sheet.png#6",
        "frames/hover/sheet.png#7",
        "frames/hover/sheet.png#0"
      ]
    },
    "tap": {
      "fps": 10,
      "loop": false,
      "nextState": "idle",
      "frames": [
        "frames/tap/sheet.png#0",
        "frames/tap/sheet.png#1",
        "frames/tap/sheet.png#2",
        "frames/tap/sheet.png#3",
        "frames/hover/sheet.png#1",
        "frames/tap/sheet.png#4",
        "frames/tap/sheet.png#5",
        "frames/tap/sheet.png#6",
        "frames/hover/sheet.png#0",
        "frames/tap/sheet.png#7",
        "frames/tap/sheet.png#8",
        "frames/tap/sheet.png#9",
        "frames/idle/sheet.png#0"
      ]
    },
    "sleep": {
      "fps": 2,
      "loop": true,
      "frames": [
        "frames/sleep/sheet.png#1",
        "frames/sleep/sheet.png#2",
        "frames/sleep/sheet.png#3",
        "frames/sleep/sheet.png#0",
        "frames/sleep/sheet.png#4",
        "frames/sleep/sheet.png#5",
        "frames/sleep/sheet.png#6",
        "frames/sleep/sheet.png#0"
      ]
    }
  }
}
