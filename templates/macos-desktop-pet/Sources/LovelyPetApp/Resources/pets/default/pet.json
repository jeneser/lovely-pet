{
  "id": "default",
  "name": "Lovely Ragdoll",
  "renderer": {
    "type": "imageAssets"
  },
  "window": {
    "width": 320,
    "height": 340
  },
  "behavior": {
    "hoverState": "hover",
    "tapState": "tap",
    "sleepState": "sleep"
  },
  "scale": 1.0,
  "anchor": "bottom-right",
  "defaultState": "idle",
  "states": {
    "idle": {
      "fps": 2,
      "loop": true,
      "frames": [
        "frames/idle/0001-stand.png",
        "frames/idle/0002-blink.png",
        "frames/idle/0001-stand.png",
        "frames/idle/0003-tail-sway.png",
        "frames/idle/0001-stand.png"
      ]
    },
    "hover": {
      "fps": 5,
      "loop": true,
      "frames": [
        "frames/hover/0001-notice.png",
        "frames/hover/0002-paw-probe.png",
        "frames/hover/0001-notice.png"
      ]
    },
    "tap": {
      "fps": 7,
      "loop": false,
      "nextState": "idle",
      "frames": [
        "frames/tap/0001-startle.png",
        "frames/hover/0002-paw-probe.png",
        "frames/hover/0001-notice.png",
        "frames/idle/0001-stand.png"
      ]
    },
    "sleep": {
      "fps": 1,
      "loop": true,
      "frames": [
        "frames/sleep/0001-loaf.png"
      ]
    }
  }
}
