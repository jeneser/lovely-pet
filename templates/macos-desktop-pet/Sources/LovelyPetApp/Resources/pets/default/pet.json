{
  "id": "default",
  "name": "Lovely Ragdoll",
  "renderer": { "type": "imageAssets" },
  "window": { "width": 320, "height": 340 },
  "behavior": {
    "hoverState": "hover",
    "tapState": "tap",
    "sleepState": "sleep"
  },
  "scale": 1.0,
  "anchor": "bottom-right",
  "defaultState": "idle",
  "states": {
    "idle": {
      "fps": 2,
      "loop": true,
      "frames": [
        "frames/idle.png.b64",
        "frames/idle.png.b64"
      ]
    },
    "hover": {
      "fps": 2,
      "loop": true,
      "frames": [
        "frames/hover.png.b64",
        "frames/hover.png.b64"
      ]
    },
    "tap": {
      "fps": 8,
      "loop": false,
      "frames": [
        "frames/tap.png.b64",
        "frames/hover.png.b64"
      ],
      "nextState": "idle"
    },
    "sleep": {
      "fps": 1,
      "loop": true,
      "frames": [
        "frames/sleep.png.b64",
        "frames/sleep.png.b64"
      ]
    }
  }
}
