{
  "id": "default",
  "name": "Lovely Ragdoll",
  "renderer": { "type": "proceduralRagdoll" },
  "window": { "width": 320, "height": 340 },
  "behavior": {
    "hoverState": "hover",
    "tapState": "tap",
    "sleepState": "sleep"
  },
  "scale": 1.0,
  "anchor": "bottom-right",
  "defaultState": "idle",
  "states": {
    "idle": {
      "fps": 12,
      "loop": true,
      "frames": []
    },
    "hover": {
      "fps": 16,
      "loop": true,
      "frames": []
    },
    "tap": {
      "fps": 18,
      "loop": false,
      "frames": [],
      "nextState": "idle"
    },
    "sleep": {
      "fps": 8,
      "loop": true,
      "frames": []
    }
  }
}
